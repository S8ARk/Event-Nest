# CERS Environment Configuration Template

# Flask Core Parameters
SECRET_KEY=your-super-secret-key-goes-here
FLASK_APP=run.py
FLASK_ENV=development

# Database Settings
# For local SQLite development (default fallback):
# DATABASE_URL=sqlite:///cers.db
# For PostgreSQL (Production/Supabase/Render):
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/cers_db

# NLP Engine
MIN_SCORE_THRESHOLD=0.1
