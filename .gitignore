# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environment variables
.env

# Virtual environment
venv/

# Flask instance folder (contains local DB like cers.db)
instance/

# Testing cache
.pytest_cache/
.coverage

# Scratch scripts, old logs, and one-off test files
NNN/

# OS generated files
.DS_Store
Thumbs.db
